# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MONGO_URI: MongoDB connection string (leave empty to fallback to local JSON file db.json)
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/my_portfolio?retryWrites=true&w=majority"

# ADMIN_PASSWORD: Password to authorize changes from the Editor Console
ADMIN_PASSWORD="admin_secure_password_123"
